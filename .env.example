PORT=3000
REDIS_URL=redis://localhost:6379
DATABASE_URL=mysql://root:root@localhost:3306/rate_limiter
RATE_LIMIT=5
RATE_WINDOW_MS=60000
LOG_LEVEL=info
ENABLE_DEFERRED_PROCESSING=false
ENABLE_RATE_LIMIT_QUEUE_FALLBACK=false
RATE_LIMIT_QUEUE_DELAY_MS=60000
QUEUE_NAME=request-processing
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_MS=1000
ENABLE_QUEUE_BATCHING=false
QUEUE_BATCH_SIZE=25
QUEUE_BATCH_WINDOW_MS=50
ENABLE_STATS_CACHE=false
STATS_CACHE_TTL_SECONDS=10
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=rate_limiter
MYSQL_PORT=3306
REDIS_PORT=6379
DOCKER_REDIS_URL=redis://redis:6379
DOCKER_DATABASE_URL=mysql://root:root@mysql:3306/rate_limiter
